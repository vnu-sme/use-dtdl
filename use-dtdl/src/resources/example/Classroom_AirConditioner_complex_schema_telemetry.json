{
  "@context": "dtmi:dtdl:context;4",
  "@id": "dtmi:com:example:AirConditioner;1",
  "@type": "Interface",
  "displayName": "Air Conditioner",
  "description": "Smart air conditioning unit for climate control.",
  "schemas": [
    {
      "@id": "dtmi:com:example:schemas:EnvironmentState;1",
      "@type": "Object",
      "fields": [
        { "name": "temperature", "schema": "double" },
        { "name": "humidity", "schema": "double" },
        { "name": "windSpeed", "schema": "double" }
      ]
    }
  ],
  "contents": [
    {
      "@type": "Property",
      "name": "onOff",
      "schema": "boolean",
      "description": "Indicates whether the air conditioner is powered on."
    },
    {
      "@type": "Telemetry",
      "name": "daylight",
      "schema": {
        "@type": "Enum",
        "valueSchema": "integer",
        "enumValues": [
          { "name": "true", "enumValue": 1 },
          { "name": "false", "enumValue": 0 }
        ]
      }
    },
    {
      "@type": "Telemetry",
      "name": "dailyTelemetryUnits",
      "description": "The unit of the daily telemetry values",
      "schema": {
        "@type": "Map",
        "mapKey": {
          "name": "telemetry",
          "schema": "string"
        },
        "mapValue": {
          "name": "unit",
          "schema": "string"
        }
      }
    },
    {
      "@type": "Telemetry",
      "name": "environmentState",
      "description": "Aggregated environmental metrics.",
      "schema": "dtmi:com:example:schemas:EnvironmentState;1"
    },
    {
      "@type": "Telemetry",
      "name": "windDirection",
      "displayName": "Wind Direction",
      "description": "Hourly wind direction for time series data.",
      "writable": true,
      "schema": {
        "@type": "Array",
        "elementSchema": "long"
      }
    }
  ]
}
