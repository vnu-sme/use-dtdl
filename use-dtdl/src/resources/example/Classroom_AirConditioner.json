{
  "@context": "dtmi:dtdl:context;4",
  "@id": "dtmi:com:example:AirConditioner;1",
  "@type": "Interface",
  "displayName": "Air Conditioner",
  "description": "Smart air conditioning unit for climate control.",
  "contents": [
    {
      "@type": "Property",
      "name": "onOff",
      "schema": "boolean",
      "description": "Indicates whether the air conditioner is powered on."
    },
    {
      "@type": "Property",
      "name": "fanSpeed",
      "schema": {
        "@type": "Enum",
        "valueSchema": "string",
        "enumValues": [
          { "name": "low", "enumValue": "low" },
          { "name": "medium", "enumValue": "medium" },
          { "name": "high", "enumValue": "high" }
        ]
      }
    },
    {
      "@type": "Property",
      "name": "targetTemperature",
      "schema": "double",
      "description": "Desired temperature set by the user."
    },
    {
      "@type": "Telemetry",
      "name": "currentTemperature",
      "schema": "double"
    },
    {
      "@type": "Telemetry",
      "name": "powerConsumption",
      "schema": "double"
    },
    {
      "@type": "Command",
      "name": "setTargetTemperature",
      "request": {
        "name": "temperatureValue",
        "schema": "double"
      }
    },
    {
      "@type": "Command",
      "name": "switchPower",
      "request": {
        "name": "powerState",
        "schema": "boolean"
      }
    }
  ]
}
